*.pyc

# NTM agent runtime logs/PIDs (ephemeral). NOTE: existing tracked files under
# these dirs must be removed from the index (`git rm --cached`) for the ignore
# to take effect on them; this only stops NEW files from being tracked.
.ntm/logs/
.ntm/pids/

# Raw fleet SSH traces (contain worker IPs/temp paths) — kept locally as working artifacts, curated .md committed instead
docs/evidence/fleet_deploy_*.txt
docs/evidence/fleet_rollback_*.txt
docs/evidence/fleet_deploy_audit_*.json

# Isolated per-session build dirs (deploy/perf/version target dirs) — never commit
/target_*/
